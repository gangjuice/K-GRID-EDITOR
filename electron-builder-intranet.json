{
  "appId": "com.kgrid.editor.intranet",
  "productName": "K-GRID EDITOR (사내망)",
  "extraMetadata": {
    "main": "main-intranet.js"
  },
  "directories": {
    "output": "dist"
  },
  "files": [
    "main-intranet.js",
    "intranet.html",
    "preload.js",
    "public/**/*",
    "data/**/*",
    "node_modules/express/**/*",
    "node_modules/xlsx/**/*",
    "node_modules/leaflet/**/*"
  ],
  "win": {
    "target": "portable"
  },
  "portable": {
    "artifactName": "K-GRID-EDITOR-사내망-v${version}.exe"
  },
  "asar": true
}
